# Exemple de configuration Apache pour un Apache EXISTANT.
# Modules requis : proxy, proxy_http, proxy_wstunnel, ssl, rewrite
# sudo a2enmod proxy proxy_http proxy_wstunnel ssl rewrite headers
#
# Copiez dans /etc/apache2/sites-available/virtualtable-rpg.conf
# puis : a2ensite virtualtable-rpg && systemctl reload apache2
#
# Remplacez DOMAIN et /opt/virtualtable-rpg/frontend par vos valeurs.
# SSL avec Let's Encrypt : certbot --apache -d DOMAIN

<VirtualHost *:80>
    ServerName DOMAIN
    RewriteEngine On
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</VirtualHost>

<VirtualHost *:443>
    ServerName DOMAIN

    # Certificat Let's Encrypt (généré par certbot)
    SSLEngine on
    SSLCertificateFile    /etc/letsencrypt/live/DOMAIN/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/DOMAIN/privkey.pem
    Include               /etc/letsencrypt/options-ssl-apache.conf

    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-Content-Type-Options nosniff

    # Répertoire des fichiers statiques du frontend
    DocumentRoot /opt/virtualtable-rpg/frontend

    <Directory /opt/virtualtable-rpg/frontend>
        Options -Indexes
        AllowOverride None
        Require all granted
    </Directory>

    # RPG Backend — API REST
    ProxyPreserveHost On
    ProxyPass        /rpg/ http://127.0.0.1:3001/rpg/
    ProxyPassReverse /rpg/ http://127.0.0.1:3001/rpg/

    # RPG Backend — Socket.io (WebSocket)
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} websocket [NC]
    RewriteCond %{HTTP:Connection} upgrade [NC]
    RewriteRule ^/rpg/socket.io/(.*) ws://127.0.0.1:3001/rpg/socket.io/$1 [P,L]
</VirtualHost>
