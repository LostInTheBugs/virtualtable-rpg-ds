# ════════════════════════════════════════════════════════════
#  VirtualTable RPG — Configuration
#  Copiez ce fichier en .env et renseignez les valeurs.
#  install.sh peut le faire automatiquement.
# ════════════════════════════════════════════════════════════

# ── Profils Docker Compose ──────────────────────────────────
# Combinaison de : db, nginx  (séparés par des virgules, ou vide)
#   db,nginx  → PostgreSQL + nginx intégrés (nouveau serveur vierge)
#   db        → PostgreSQL intégré, nginx/apache géré par l'hôte
#   nginx     → nginx intégré, PostgreSQL externe
#   (vide)    → tout géré par l'hôte, juste le backend en Docker
COMPOSE_PROFILES=db,nginx

# ── Domaine ─────────────────────────────────────────────────
# Nom de domaine pointant vers ce serveur
DOMAIN=virtualtable.example.com

# URL publique de l'application (utilisée par le backend pour CORS)
ALLOWED_ORIGIN=https://virtualtable.example.com

# Email pour Let's Encrypt (requis si profil nginx)
CERTBOT_EMAIL=admin@example.com

# ── Backend — port et binding ────────────────────────────────
# Port sur lequel le backend écoute côté hôte
RPG_PORT=3001
# Interface de binding :
#   127.0.0.1  → accessible uniquement en local (recommandé avec proxy externe)
#   0.0.0.0    → accessible depuis l'extérieur (si pas de proxy du tout)
RPG_BIND=127.0.0.1

# ── Base de données ──────────────────────────────────────────
# Si COMPOSE_PROFILES contient 'db' :
#   RPG_DB_PASSWORD est utilisé, DATABASE_URL est construit automatiquement.
#
# Si vous utilisez un PostgreSQL externe (pas de profil 'db') :
#   Renseignez DATABASE_URL directement, laissez RPG_DB_PASSWORD vide.
RPG_DB_PASSWORD=
DATABASE_URL=

# ── Secrets ──────────────────────────────────────────────────
# Clé secrète JWT — laissez vide, install.sh génère une valeur aléatoire.
JWT_SECRET=
