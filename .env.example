# ── Domaine ─────────────────────────────────────────────────────
# Nom de domaine pointant vers ce serveur (sans https://)
DOMAIN=virtualtable.example.com

# Email pour Let's Encrypt (notifications d'expiration de certificat)
CERTBOT_EMAIL=admin@example.com

# ── Secrets ──────────────────────────────────────────────────────
# Laissez vide : install.sh génère des valeurs aléatoires automatiquement.
# Renseignez des valeurs si vous voulez les fixer (ex : migration de données).

# Mot de passe PostgreSQL pour l'utilisateur 'rpg'
RPG_DB_PASSWORD=

# Clé secrète JWT (signature des tokens d'authentification)
JWT_SECRET=
